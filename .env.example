# Copy this file to .env and fill in your credentials.
# .env is gitignored — never commit it.

# OpenAI API key (for GPT-4o spec updates, build diagnosis, review)
OPENAI_API_KEY=sk-proj-YOUR_KEY_HERE

# Open Build Service credentials (api.opensuse.org or your private OBS)
OBS_USER=your-obs-username
OBS_PASS=your-obs-password
OBS_API_URL=https://api.opensuse.org

# Default OBS project to scan/upgrade (can be overridden per command)
OBS_PROJECT=systemsmanagement:ansible

# GPT model (default: gpt-4o)
# OPENAI_MODEL=gpt-4o
